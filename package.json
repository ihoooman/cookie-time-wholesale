{
  "name": "cookie-time-wholesale",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build && node --test tests/rendered-html.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate",
    "cf:setup": "wrangler d1 create cookie-time-wholesale --binding DB --update-config && wrangler kv namespace create cookie-time-media --binding MEDIA_KV --update-config && npm run cf:prepare",
    "cf:prepare": "node scripts/prepare-cloudflare.mjs && wrangler types",
    "cf:build": "npm run cf:prepare && CLOUDFLARE_DIRECT_DEPLOY=1 npm run build",
    "cf:migrate": "npm run cf:prepare && wrangler d1 migrations apply DB --remote",
    "cf:deploy": "npm run cf:migrate && CLOUDFLARE_DIRECT_DEPLOY=1 vinext deploy --skip-build",
    "cf:dry-run": "CLOUDFLARE_DIRECT_DEPLOY=1 vinext deploy --dry-run"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.25.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
