{
  "name": "cookie-time-wholesale",
  "version": "0.1.0",
  "private": true,
  "description": "Production Persian wholesale ordering PWA for Cookie Time, deployed on Cloudflare Workers.",
  "author": "Cookie Time",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://seller.time-cookie.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/ihoooman/cookie-time-wholesale.git"
  },
  "bugs": {
    "url": "https://github.com/ihoooman/cookie-time-wholesale/issues"
  },
  "keywords": [
    "cloudflare-workers",
    "ecommerce",
    "nextjs",
    "persian",
    "pwa",
    "rtl",
    "typescript",
    "wholesale"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build && node --test tests/rendered-html.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --max-warnings=0",
    "typecheck": "npm run cf:prepare && tsc --noEmit --incremental false",
    "audit": "npm audit --omit=dev --audit-level=high",
    "check": "npm run lint && npm run typecheck && npm run audit && npm run test",
    "db:generate": "drizzle-kit generate",
    "cf:setup": "wrangler d1 create cookie-time-wholesale --binding DB --update-config && wrangler kv namespace create cookie-time-media --binding MEDIA_KV --update-config && npm run cf:prepare",
    "cf:prepare": "node scripts/prepare-cloudflare.mjs && wrangler types",
    "cf:build": "npm run cf:prepare && CLOUDFLARE_DIRECT_DEPLOY=1 npm run build",
    "cf:migrate": "npm run cf:prepare && wrangler d1 migrations apply DB --remote",
    "cf:deploy": "npm run cf:migrate && CLOUDFLARE_DIRECT_DEPLOY=1 vinext deploy --skip-build",
    "cf:dry-run": "CLOUDFLARE_DIRECT_DEPLOY=1 vinext deploy --dry-run"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.25.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.1",
    "@types/node": "22.19.19",
    "@types/react": "^19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitejs/plugin-rsc": "^0.5.28",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "^16.2.10",
    "react-server-dom-webpack": "^19.2.7",
    "typescript": "7.0.2",
    "vinext": "0.0.50",
    "vite": "^8.1.5",
    "wrangler": "^4.112.0"
  },
  "type": "module",
  "packageManager": "npm@11.8.0"
}
